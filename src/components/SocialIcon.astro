---
// 定义组件的属性接口，使用TypeScript进行类型检查
interface Props {
  // 平台类型，限定为四种可选值
  platform: 'github' | 'bilibili' | 'youtube' | 'email';
  // 链接地址
  href: string;
  // 图标尺寸，可选值：小、中、大，默认为'md'
  size?: 'sm' | 'md' | 'lg';
  // 自定义CSS类名
  class?: string;
}

// 从Astro props中解构获取各属性，并设置默认值
const { platform, href, size = 'md', class: className = '' } = Astro.props;

// 定义不同尺寸对应的Tailwind CSS类
const sizeClasses = {
  sm: 'w-7 h-7',   // 小尺寸：宽高28px
  md: 'w-8 h-8',   // 中尺寸：宽高32px（默认）
  lg: 'w-10 h-10'  // 大尺寸：宽高40px
};

// 定义各平台的SVG图标路径
const icons = {
  // GitHub图标路径：GitHub的章鱼猫logo
  github: `<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>`,
  // Bilibili图标路径：B站的小电视logo
  bilibili: `<path d="M17.523 2.999a1.535 1.535 0 0 0-1.462 1.078 2.53 2.53 0 0 1-2.343 1.683h-.036a2.53 2.53 0 0 1-2.343-1.683 1.535 1.535 0 0 0-1.462-1.078C8.367 2.999 7 4.544 7 7.587v1.055c0 1.997-.373 3.86-2.066 4.714a.526.526 0 0 0-.228.674c.647 1.698 1.712 2.89 2.89 3.412v1.985a.586.586 0 0 0 .586.586h1.173a.586.586 0 0 0 .586-.586V18.22c.693.09 1.404.137 2.116.137s1.423-.047 2.116-.137v1.208a.586.586 0 0 0 .586.586h1.173a.586.586 0 0 0 .586-.586v-1.985c1.178-.522 2.243-1.714 2.89-3.412a.526.526 0 0 0-.228-.674c-1.693-.854-2.066-2.717-2.066-4.714V7.587c0-3.043-1.367-4.588-2.89-4.588zM9.943 13.74a1.53 1.53 0 1 1 0-3.06 1.53 1.53 0 0 1 0 3.06zm5.123-1.53a1.53 1.53 0 1 1-3.06 0 1.53 1.53 0 0 1 3.06 0z"/>`,
  // YouTube图标路径：YouTube的播放按钮logo
  youtube: `<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>`,
  // 邮箱图标路径：邮件信封logo
  email: `<path d="M12 12.713l-11.985-9.713h23.97L12 12.713zM0 20.287V4.969l11.26 9.128c.41.332.94.332 1.35 0L24 4.969v15.318H0z"/>`
};

// 定义各平台的显示标题，用于鼠标悬停提示和无障碍标签
const titles = {
  github: 'GitHub',      // GitHub平台标题
  bilibili: 'Bilibili',  // Bilibili平台标题
  youtube: 'YouTube',    // YouTube平台标题
  email: '邮箱'          // 邮箱标题
};

// 判断是否为外部链接（非mailto:开头的链接）
const isExternal = !href.startsWith('mailto:');
---

<!-- 社交图标链接元素 -->
<a
  href={href}  <!-- 链接地址 -->
  target={isExternal ? '_blank' : undefined}  <!-- 外部链接在新标签页打开 -->
  rel={isExternal ? 'noopener noreferrer' : undefined}  <!-- 外部链接添加安全属性 -->
  title={titles[platform]}  <!-- 鼠标悬停提示文本 -->
  class:list={['text-blue-500 hover:text-blue-600 transition-colors', className]}  <!-- Tailwind CSS样式类 -->
  aria-label={titles[platform]}  <!-- 无障碍标签，供屏幕阅读器使用 -->
>
  <!-- SVG图标元素 -->
  <svg class:list={['icon', sizeClasses[size]]} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <!-- 使用Fragment动态插入对应平台的SVG路径 -->
    <Fragment set:html={icons[platform]} />
  </svg>
</a>
