---
// 主题切换按钮组件
// 用于在浅色模式和深色模式之间切换
---

<!-- 主题切换按钮 -->
<button
  id="themeToggle"  <!-- 按钮唯一标识符，用于JavaScript获取元素 -->
  class="theme-toggle"  <!-- CSS样式类 -->
  aria-label="切换深色/浅色模式"  <!-- 无障碍标签，供屏幕阅读器使用 -->
  title="切换主题"  <!-- 鼠标悬停提示文本 -->
>
  <!-- 太阳图标（浅色模式时显示） -->
  <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <circle cx="12" cy="12" r="5"/>  <!-- 太阳中心圆 -->
    <line x1="12" y1="1" x2="12" y2="3"/>  <!-- 上方光线 -->
    <line x1="12" y1="21" x2="12" y2="23"/>  <!-- 下方光线 -->
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>  <!-- 左上光线 -->
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>  <!-- 右下光线 -->
    <line x1="1" y1="12" x2="3" y2="12"/>  <!-- 左侧光线 -->
    <line x1="21" y1="12" x2="23" y2="12"/>  <!-- 右侧光线 -->
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>  <!-- 左下光线 -->
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>  <!-- 右上光线 -->
  </svg>
  <!-- 月亮图标（深色模式时显示） -->
  <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>  <!-- 月牙形状 -->
  </svg>
</button>

<style>
  /* 主题切换按钮样式 */
  .theme-toggle {
    position: fixed;  /* 固定定位，不随页面滚动 */
    top: 20px;  /* 距离顶部20px */
    right: 20px;  /* 距离右侧20px */
    width: 44px;  /* 按钮宽度 */
    height: 44px;  /* 按钮高度 */
    border-radius: 50%;  /* 圆形按钮 */
    border: none;  /* 无边框 */
    background: var(--nav-bg, rgba(255, 255, 255, 0.85));  /* 背景色，使用CSS变量或默认值 */
    color: var(--text-color, #333);  /* 文字颜色，使用CSS变量或默认值 */
    cursor: pointer;  /* 鼠标指针样式 */
    backdrop-filter: blur(10px);  /* 背景模糊效果 */
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);  /* 阴影效果 */
    transition: all 0.3s;  /* 过渡动画，时长0.3秒 */
    z-index: 101;  /* 层级，确保在其他元素之上 */
    display: flex;  /* 弹性布局 */
    align-items: center;  /* 垂直居中 */
    justify-content: center;  /* 水平居中 */
    padding: 0;  /* 无内边距 */
  }

  /* 按钮悬停效果 */
  .theme-toggle:hover {
    transform: scale(1.1);  /* 放大1.1倍 */
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);  /* 增强阴影 */
  }

  /* 按钮内SVG图标样式 */
  .theme-toggle svg {
    width: 22px;  /* 图标宽度 */
    height: 22px;  /* 图标高度 */
  }

  /* 太阳图标默认显示 */
  .sun-icon {
    display: block;
  }

  /* 月亮图标默认隐藏 */
  .moon-icon {
    display: none;
  }

  /* 深色模式下太阳图标隐藏 */
  :global(.dark) .sun-icon {
    display: none;
  }

  /* 深色模式下月亮图标显示 */
  :global(.dark) .moon-icon {
    display: block;
  }
</style>

<script>
  // 获取主题切换按钮元素
  const toggle = document.getElementById('themeToggle');

  // 初始化主题设置
  // 从localStorage获取已保存的主题偏好
  const savedTheme = localStorage.getItem('theme');
  // 检测系统是否偏好深色模式
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

  // 如果已保存深色主题，或未保存主题但系统偏好深色模式，则应用深色主题
  if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
    document.documentElement.classList.add('dark');  // 在html元素上添加dark类
  }

  // 为按钮添加点击事件监听器
  toggle?.addEventListener('click', () => {
    // 切换dark类
    document.documentElement.classList.toggle('dark');
    // 检查当前是否为深色模式
    const isDark = document.documentElement.classList.contains('dark');
    // 将主题偏好保存到localStorage
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
