---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import '../styles/global.css';
---

<Layout title="关于 - HJ">
  <div class="bg"></div>

  <div class="container mx-auto px-4 py-8">
    <Navigation currentPage="about" />

    <div class="page-content max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">关于我</h2>

      <div class="about-section flex flex-col md:flex-row gap-8 items-center">
        <div class="avatar-container flex-shrink-0">
          <img
            src="https://raw.githubusercontent.com/liupuzhi/mysite/main/assets/01.png"
            alt="HJ"
            class="avatar-large w-52 h-52 rounded-full object-cover border-4 border-white shadow-xl"
          />
        </div>

        <div class="info flex-1">
          <h3 class="text-2xl font-bold text-gray-900 mb-1">H J</h3>
          <p class="title text-blue-600 font-semibold mb-6">中山大学学生</p>

          <div class="bio-text text-gray-700 leading-relaxed mb-8">
            <p class="mb-4">👋 你好！我是一名对设计和技术充满热情的学生。</p>
            <p class="mb-4">我喜欢探索创造性的解决方案，并致力于将美学与功能完美结合。</p>
            <p class="mb-4">在中山大学的学习生活中，我不断积累经验，提升自己的专业能力。</p>
          </div>

          <div class="skills mb-8">
            <h4 class="text-lg font-bold text-gray-800 mb-3">技能</h4>
            <div class="skill-tags flex flex-wrap gap-2">
              <span class="skill-tag bg-blue-50 text-blue-600 px-4 py-1.5 rounded-full text-sm font-medium">UI/UX 设计</span>
              <span class="skill-tag bg-blue-50 text-blue-600 px-4 py-1.5 rounded-full text-sm font-medium">前端开发</span>
              <span class="skill-tag bg-blue-50 text-blue-600 px-4 py-1.5 rounded-full text-sm font-medium">创意设计</span>
              <span class="skill-tag bg-blue-50 text-blue-600 px-4 py-1.5 rounded-full text-sm font-medium">项目管理</span>
            </div>
          </div>

          <div class="social-links flex space-x-6 pt-4 border-t border-gray-200">
            <a href="https://github.com/" target="_blank" title="GitHub" class="text-2xl text-blue-500 hover:text-blue-600 transition-colors">
              <svg class="icon w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                <!-- GitHub 图标 - 蓝色 -->
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" fill="#00AEEC"/>
              </svg>
            </a>
            <a href="https://space.bilibili.com/" target="_blank" title="Bilibili" class="text-2xl text-blue-500 hover:text-blue-600 transition-colors">
              <svg class="icon w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                <path fill="#00AEEC" d="M17.523 2.999a1.535 1.535 0 0 0-1.462 1.078 2.53 2.53 0 0 1-2.343 1.683h-.036a2.53 2.53 0 0 1-2.343-1.683 1.535 1.535 0 0 0-1.462-1.078C8.367 2.999 7 4.544 7 7.587v1.055c0 1.997-.373 3.86-2.066 4.714a.526.526 0 0 0-.228.674c.647 1.698 1.712 2.89 2.89 3.412v1.985a.586.586 0 0 0 .586.586h1.173a.586.586 0 0 0 .586-.586V18.22c.693.09 1.404.137 2.116.137s1.423-.047 2.116-.137v1.208a.586.586 0 0 0 .586.586h1.173a.586.586 0 0 0 .586-.586v-1.985c1.178-.522 2.243-1.714 2.89-3.412a.526.526 0 0 0-.228-.674c-1.693-.854-2.066-2.717-2.066-4.714V7.587c0-3.043-1.367-4.588-2.89-4.588zM9.943 13.74a1.53 1.53 0 1 1 0-3.06 1.53 1.53 0 0 1 0 3.06zm5.123-1.53a1.53 1.53 0 1 1-3.06 0 1.53 1.53 0 0 1 3.06 0z"/>
              </svg>
            </a>
            <a href="https://www.youtube.com/" target="_blank" title="YouTube" class="text-2xl text-blue-500 hover:text-blue-600 transition-colors">
              <svg class="icon w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                <!-- YouTube 图标 - 蓝色 -->
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" fill="#00AEEC"/>
              </svg>
            </a>
            <a href="mailto:xiaoranyu0807@gmail.com" title="邮箱" class="text-2xl text-blue-500 hover:text-blue-600 transition-colors">
              <svg class="icon w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                <!-- 邮箱图标 - 蓝色 -->
                <path d="M12 12.713l-11.985-9.713h23.97L12 12.713zM0 20.287V4.969l11.26 9.128c.41.332.94.332 1.35 0L24 4.969v15.318H0z" fill="#00AEEC"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
