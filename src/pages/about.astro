---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import SocialIcon from '../components/SocialIcon.astro';
import '../styles/global.css';
---

<Layout title="About - HJ" description="Background, focus areas, and links for HJ.">
  <div class="bg"></div>

  <div class="container mx-auto px-4 py-8">
    <Navigation currentPage="about" />

    <div class="page-content max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">About Me</h2>

      <div class="about-section flex flex-col md:flex-row gap-8 items-center">
        <div class="avatar-container flex-shrink-0">
          <img
            src="/avatar.png"
            alt="Portrait of HJ"
            class="avatar-large w-52 h-52 rounded-full object-cover border-4 border-white shadow-xl"
            loading="lazy"
          />
        </div>

        <div class="info flex-1">
          <h3 class="text-2xl font-bold text-gray-900 mb-1">HJ</h3>
          <p class="title text-blue-600 font-semibold mb-6">Student at Sun Yat-sen University</p>

          <div class="bio-text text-gray-700 leading-relaxed mb-8">
            <p class="mb-4">I am interested in visual communication, interaction design, and the craft of building for the web.</p>
            <p class="mb-4">What matters most to me is turning ideas into pages and experiences that people can actually use.</p>
            <p class="mb-4">This portfolio is a simple home for that process and for the work I want to keep improving.</p>
          </div>

          <div class="skills mb-8">
            <h4 class="text-lg font-bold text-gray-800 mb-3">Focus Areas</h4>
            <div class="skill-tags flex flex-wrap gap-2">
              <span class="skill-tag bg-blue-50 text-blue-600 px-4 py-1.5 rounded-full text-sm font-medium">UI / UX Design</span>
              <span class="skill-tag bg-blue-50 text-blue-600 px-4 py-1.5 rounded-full text-sm font-medium">Front-end Development</span>
              <span class="skill-tag bg-blue-50 text-blue-600 px-4 py-1.5 rounded-full text-sm font-medium">Visual Direction</span>
              <span class="skill-tag bg-blue-50 text-blue-600 px-4 py-1.5 rounded-full text-sm font-medium">Project Collaboration</span>
            </div>
          </div>

          <div class="social-links flex space-x-6 pt-4 border-t border-gray-200">
            <SocialIcon platform="github" href="https://github.com/" size="sm" />
            <SocialIcon platform="bilibili" href="https://space.bilibili.com/" size="sm" />
            <SocialIcon platform="youtube" href="https://www.youtube.com/" size="sm" />
            <SocialIcon platform="email" href="mailto:xiaoranyu0807@gmail.com" size="sm" />
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
