---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import SocialIcon from '../components/SocialIcon.astro';
import '../styles/global.css';

const formspreeAction = 'https://formspree.io/f/YOUR_FORM_ID';
const formConfigured = !formspreeAction.includes('YOUR_FORM_ID');
---

<Layout title="Contact - HJ" description="Ways to reach HJ by email or social links.">
  <div class="bg"></div>

  <div class="container mx-auto px-4 py-8">
    <Navigation currentPage="contact" />

    <div class="page-content max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Contact</h2>

      <div class="contact-info text-center">
        <p class="text-center text-gray-600 text-xl mb-10">You can reach me through the links below.</p>

        <div class="contact-cards grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
          <div class="contact-card bg-white p-8 rounded-2xl text-center border-2 border-gray-200 transition-all duration-300 hover:border-blue-300 hover:shadow-lg">
            <div class="card-icon w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-full flex items-center justify-center">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="M22 4L12 13L2 4" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Email</h3>
            <p class="text-gray-600">
              <a href="mailto:xiaoranyu0807@gmail.com" class="text-blue-600 font-medium hover:text-blue-700 transition-colors">
                xiaoranyu0807@gmail.com
              </a>
            </p>
          </div>

          <div class="contact-card bg-white p-8 rounded-2xl text-center border-2 border-gray-200 transition-all duration-300 hover:border-blue-300 hover:shadow-lg">
            <div class="card-icon w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-full flex items-center justify-center">
              <SocialIcon platform="github" href="https://github.com/" class="text-white hover:text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">GitHub</h3>
            <p class="text-gray-600">
              <a href="https://github.com/" target="_blank" rel="noopener noreferrer" class="text-blue-600 font-medium hover:text-blue-700 transition-colors">
                Visit GitHub
              </a>
            </p>
          </div>

          <div class="contact-card bg-white p-8 rounded-2xl text-center border-2 border-gray-200 transition-all duration-300 hover:border-blue-300 hover:shadow-lg">
            <div class="card-icon w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-full flex items-center justify-center">
              <SocialIcon platform="bilibili" href="https://bilibili.com/" class="text-white hover:text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Bilibili</h3>
            <p class="text-gray-600">
              <a href="https://bilibili.com/" target="_blank" rel="noopener noreferrer" class="text-blue-600 font-medium hover:text-blue-700 transition-colors">
                Visit Bilibili
              </a>
            </p>
          </div>
        </div>

        <div class="message pt-8 border-t border-gray-200">
          <p class="text-gray-600 text-lg mb-6">You can also leave a message here:</p>

          {formConfigured ? (
            <form method="POST" action={formspreeAction} class="contact-form max-w-2xl mx-auto">
              <input type="hidden" name="_subject" value="New message from HJ portfolio" />
              <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

              <div class="form-group mb-6">
                <label for="name" class="block text-gray-800 font-medium mb-2 text-lg">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  placeholder="Your name"
                  required
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-lg font-sans transition-all duration-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200"
                />
              </div>

              <div class="form-group mb-6">
                <label for="email" class="block text-gray-800 font-medium mb-2 text-lg">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="Your email"
                  required
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-lg font-sans transition-all duration-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200"
                />
              </div>

              <div class="form-group mb-8">
                <label for="message" class="block text-gray-800 font-medium mb-2 text-lg">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  placeholder="What would you like to share?"
                  required
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-lg font-sans transition-all duration-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 resize-vertical min-h-[150px]"
                ></textarea>
              </div>

              <button
                type="submit"
                class="submit-btn bg-gradient-to-r from-blue-500 to-purple-600 text-white font-bold px-8 py-4 rounded-xl text-lg cursor-pointer transition-all duration-300 hover:from-blue-600 hover:to-purple-700 hover:shadow-lg mx-auto block"
              >
                Send message
              </button>
            </form>
          ) : (
            <div class="max-w-2xl mx-auto rounded-2xl border-2 border-amber-200 bg-amber-50 px-6 py-5 text-left text-amber-900">
              <p class="font-semibold mb-2">Form not configured</p>
              <p class="leading-relaxed">
                This page still uses a placeholder Formspree ID, so online submissions are currently disabled. Please use email or the social links above instead.
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>
