---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import '../styles/global.css';
---

<Layout title="联系 - HJ">
  <div class="bg"></div>

  <div class="container mx-auto px-4 py-8">
    <Navigation currentPage="contact" />

    <div class="page-content max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">联系我</h2>

      <div class="contact-info text-center">
        <p class="text-center text-gray-600 text-xl mb-10">📬 欢迎通过以下方式与我取得联系：</p>

        <div class="contact-cards grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
          <div class="contact-card bg-white p-8 rounded-2xl text-center border-2 border-gray-200 transition-all duration-300 hover:border-blue-300 hover:shadow-lg">
            <div class="card-icon w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-full flex items-center justify-center">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="M22 4L12 13L2 4"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">邮箱</h3>
            <p class="text-gray-600">
              <a href="mailto:xiaoranyu0807@gmail.com" class="text-blue-600 font-medium hover:text-blue-700 transition-colors">xiaoranyu0807@gmail.com</a>
            </p>
          </div>

          <div class="contact-card bg-white p-8 rounded-2xl text-center border-2 border-gray-200 transition-all duration-300 hover:border-blue-300 hover:shadow-lg">
            <div class="card-icon w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-full flex items-center justify-center">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">GitHub</h3>
            <p class="text-gray-600">
              <a href="https://github.com/" target="_blank" class="text-blue-600 font-medium hover:text-blue-700 transition-colors">github.com/yourname</a>
            </p>
          </div>

          <div class="contact-card bg-white p-8 rounded-2xl text-center border-2 border-gray-200 transition-all duration-300 hover:border-blue-300 hover:shadow-lg">
            <div class="card-icon w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-full flex items-center justify-center">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.523 2.999a1.535 1.535 0 0 0-1.462 1.078 2.53 2.53 0 0 1-2.343 1.683h-.036a2.53 2.53 0 0 1-2.343-1.683 1.535 1.535 0 0 0-1.462-1.078C8.367 2.999 7 4.544 7 7.587v1.055c0 1.997-.373 3.86-2.066 4.714a.526.526 0 0 0-.228.674c.647 1.698 1.712 2.89 2.89 3.412v1.985a.586.586 0 0 0 .586.586h1.173a.586.586 0 0 0 .586-.586V18.22c.693.09 1.404.137 2.116.137s1.423-.047 2.116-.137v1.208a.586.586 0 0 0 .586.586h1.173a.586.586 0 0 0 .586-.586v-1.985c1.178-.522 2.243-1.714 2.89-3.412a.526.526 0 0 0-.228-.674c-1.693-.854-2.066-2.717-2.066-4.714V7.587c0-3.043-1.367-4.588-2.89-4.588zM9.943 13.74a1.53 1.53 0 1 1 0-3.06 1.53 1.53 0 0 1 0 3.06zm5.123-1.53a1.53 1.53 0 1 1-3.06 0 1.53 1.53 0 0 1 3.06 0z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Bilibili</h3>
            <p class="text-gray-600">
              <a href="https://bilibili.com/" target="_blank" class="text-blue-600 font-medium hover:text-blue-700 transition-colors">bilibili.com/yourname</a>
            </p>
          </div>
        </div>

        <div class="message pt-8 border-t border-gray-200">
          <p class="text-gray-600 text-lg mb-6">📧 也可以直接在这里给我发送消息：</p>
          <form method="POST" action="https://formspree.io/f/YOUR_FORM_ID" class="contact-form max-w-2xl mx-auto" id="contactForm">
      <input type="hidden" name="_subject" value="新消息来自HJ的个人主页">
      <input type="text" name="_gotcha" style="display:none">
      <!-- 表单字段保持不变 -->
            <div class="form-group mb-6">
              <label for="name" class="block text-gray-800 font-medium mb-2 text-lg">姓名</label>
              <input type="text" id="name" name="name" placeholder="你的姓名" required class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-lg font-sans transition-all duration-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />
            </div>

            <div class="form-group mb-6">
              <label for="email" class="block text-gray-800 font-medium mb-2 text-lg">邮箱</label>
              <input type="email" id="email" name="email" placeholder="你的邮箱" required class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-lg font-sans transition-all duration-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />
            </div>

            <div class="form-group mb-8">
              <label for="message" class="block text-gray-800 font-medium mb-2 text-lg">消息</label>
              <textarea id="message" name="message" rows="5" placeholder="你想说什么..." required class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-lg font-sans transition-all duration-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 resize-vertical min-h-[150px]"></textarea>
            </div>

            <button type="submit" class="submit-btn bg-gradient-to-r from-blue-500 to-purple-600 text-white font-bold px-8 py-4 rounded-xl text-lg cursor-pointer transition-all duration-300 hover:from-blue-600 hover:to-purple-700 hover:shadow-lg mx-auto block">
              发送消息
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('contactForm')?.addEventListener('submit', (e) => {
      e.preventDefault();

      // 获取表单数据
      const formData = new FormData(e.target);
      const name = formData.get('name');
      const email = formData.get('email');
      const message = formData.get('message');

      // 在这里可以添加实际的表单提交逻辑，例如调用API
      console.log({ name, email, message });

      // 显示成功消息
      alert('感谢您的消息！我们会尽快回复您。');

      // 重置表单
      e.target.reset();
    });
  </script>
</Layout>
