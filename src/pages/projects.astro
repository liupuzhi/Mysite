---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import '../styles/global.css';

const projects = [
  { title: '项目一', tag: '设计', description: '这是一个设计项目的描述，展示了我的设计能力。', year: '2024' },
  { title: '项目二', tag: '开发', description: '这是一个开发项目的描述，展示了我的编程能力。', year: '2024' },
  { title: '项目三', tag: '设计', description: '这是另一个设计项目的描述。', year: '2024' },
  { title: '项目四', tag: '开发', description: '这是另一个开发项目的描述。', year: '2024' },
];
---

<Layout title="作品集 - HJ">
  <div class="bg"></div>

  <div class="container mx-auto px-4 py-8">
    <Navigation currentPage="projects" />

    <div class="page-content max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">我的作品</h2>

      <div class="project-grid grid grid-cols-1 md:grid-cols-2 gap-8">
        {projects.map((project) => (
          <article class="project-card bg-white rounded-2xl p-8 border-2 border-gray-200 transition-all duration-300 hover:border-blue-300 hover:shadow-lg">
            <div class="card-header flex justify-between items-center mb-4">
              <h3 class="text-2xl font-bold text-gray-800">{project.title}</h3>
              <span class="tag bg-gradient-to-r from-blue-500 to-purple-600 text-white px-4 py-1 rounded-full text-sm font-medium">{project.tag}</span>
            </div>
            <p class="description text-gray-600 leading-relaxed mb-6">{project.description}</p>
            <div class="card-footer flex justify-between items-center pt-4 border-t border-gray-200">
              <span class="date text-gray-500 text-sm">{project.year}</span>
              <a href="#" class="view-btn text-blue-600 font-medium hover:text-blue-700 transition-colors">查看详情</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</Layout>
