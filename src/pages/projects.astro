---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import '../styles/global.css';

const projects = [
  {
    title: 'Portfolio Site Refresh',
    tag: 'Front-end',
    description: 'A small ongoing effort to improve page structure, visual hierarchy, and site interaction.',
    year: '2026',
  },
  {
    title: 'Campus Visual Study',
    tag: 'Design',
    description: 'A set of layout and poster exercises focused on stronger composition and presentation.',
    year: '2025',
  },
  {
    title: 'Component Style Experiments',
    tag: 'UI',
    description: 'A series of button, card, and navigation explorations with reuse and consistency in mind.',
    year: '2025',
  },
  {
    title: 'Archive Plan',
    tag: 'Planning',
    description: 'An effort to collect scattered exercises and turn them into a more complete body of work.',
    year: '2024',
  },
];
---

<Layout title="Projects - HJ" description="A snapshot of project directions and recent work.">
  <div class="bg"></div>

  <div class="container mx-auto px-4 py-8">
    <Navigation currentPage="projects" />

    <div class="page-content max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Projects</h2>

      <div class="project-grid grid grid-cols-1 md:grid-cols-2 gap-8">
        {projects.map((project) => (
          <article class="project-card bg-white rounded-2xl p-8 border-2 border-gray-200 transition-all duration-300 hover:border-blue-300 hover:shadow-lg">
            <div class="card-header flex justify-between items-center mb-4">
              <h3 class="text-2xl font-bold text-gray-800">{project.title}</h3>
              <span class="tag bg-gradient-to-r from-blue-500 to-purple-600 text-white px-4 py-1 rounded-full text-sm font-medium">
                {project.tag}
              </span>
            </div>

            <p class="description text-gray-600 leading-relaxed mb-6">{project.description}</p>

            <div class="card-footer flex justify-between items-center pt-4 border-t border-gray-200">
              <span class="date text-gray-500 text-sm">{project.year}</span>
              <span class="view-btn text-blue-600 font-medium">Details coming soon</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</Layout>
