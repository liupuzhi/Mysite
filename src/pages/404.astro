---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import '../styles/global.css';
---

<Layout title="Page Not Found - HJ" description="The page you requested does not exist.">
  <div class="bg"></div>

  <div class="container mx-auto px-4 py-8">
    <Navigation currentPage="" />

    <div class="page-content max-w-2xl mx-auto text-center py-16">
      <h1 class="text-8xl font-bold text-gray-900 mb-4">404</h1>
      <h2 class="text-2xl font-semibold text-gray-700 mb-6">Page not found</h2>
      <p class="text-gray-600 mb-8">Sorry, the page you requested does not exist or the link has changed.</p>
      <a
        href="/"
        class="inline-block bg-gradient-to-r from-blue-500 to-purple-600 text-white font-bold px-8 py-3 rounded-xl transition-all duration-300 hover:from-blue-600 hover:to-purple-700 hover:shadow-lg"
      >
        Back to home
      </a>
    </div>
  </div>
</Layout>
