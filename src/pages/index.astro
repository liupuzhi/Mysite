---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import SocialIcon from '../components/SocialIcon.astro';
import '../styles/global.css';
---

<Layout
  title="HJ - Home"
  description="HJ portfolio homepage with profile, social links, and featured directions."
  url="https://hj-portfolio.com/"
>
  <div class="bg"></div>

  <div class="container mx-auto px-4 py-8">
    <Navigation currentPage="home" />

    <div class="page-content flex flex-col items-center justify-center py-12 text-center max-w-4xl mx-auto">
      <img
        src="/avatar.png"
        alt="Portrait of HJ"
        class="avatar w-48 h-48 rounded-full object-cover border-4 border-white mb-6 shadow-xl"
        loading="lazy"
      />

      <h1 class="text-5xl font-bold text-gray-900 mb-2 tracking-tight">HJ</h1>
      <div class="subtitle text-2xl text-gray-600 mb-8">Student at Sun Yat-sen University</div>

      <div class="bio text-lg leading-relaxed text-gray-700 mb-10 max-w-2xl mx-auto">
        <p>I am building experience across design, visual storytelling, and front-end development.</p>
        <p>This site is a place to collect my projects, background, and the best ways to get in touch.</p>
      </div>

      <div class="social-links flex space-x-6 mb-8">
        <SocialIcon platform="github" href="https://github.com/" />
        <SocialIcon platform="bilibili" href="https://space.bilibili.com/" />
        <SocialIcon platform="youtube" href="https://www.youtube.com/" />
        <SocialIcon platform="email" href="mailto:xiaoranyu0807@gmail.com" />
      </div>
    </div>

    <audio id="bgMusic" loop>
      <source src="/background-music.mp3" type="audio/mpeg" />
    </audio>

    <button
      class="music-control"
      id="musicBtn"
      type="button"
      title="Play background music"
      aria-label="Play background music"
    >
      <svg
        id="musicIcon"
        class="w-6 h-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M11 5L6 9H2v6h4l5 4V5z" />
        <line x1="23" y1="9" x2="17" y2="15" />
        <line x1="17" y1="9" x2="23" y2="15" />
      </svg>
    </button>
  </div>

  <script>
    const music = document.getElementById('bgMusic');
    const btn = document.getElementById('musicBtn');
    const icon = document.getElementById('musicIcon');

    const playIcon =
      '<path d="M11 5L6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>';
    const pauseIcon =
      '<path d="M11 5L6 9H2v6h4l5 4V5z"/><line x1="19" y1="9" x2="19" y2="15"/><line x1="21" y1="9" x2="21" y2="15"/>';

    const updateMusicState = (isPlaying: boolean) => {
      if (!btn || !icon) return;

      icon.innerHTML = isPlaying ? pauseIcon : playIcon;
      btn.setAttribute('title', isPlaying ? 'Pause background music' : 'Play background music');
      btn.setAttribute('aria-label', isPlaying ? 'Pause background music' : 'Play background music');
    };

    updateMusicState(false);

    btn?.addEventListener('click', async () => {
      if (!(music instanceof HTMLAudioElement)) return;

      if (music.paused) {
        try {
          await music.play();
          updateMusicState(true);
        } catch (error) {
          console.warn('Background music playback was blocked by the browser.', error);
          updateMusicState(false);
        }
      } else {
        music.pause();
        updateMusicState(false);
      }
    });
  </script>
</Layout>
