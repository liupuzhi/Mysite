---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HJ - 首页">
  <div class="bg"></div>

  <div class="container">
    <div class="nav">
      <a href="/" class="active">首页</a>
      <a href="/projects">作品集</a>
      <a href="/about">关于</a>
      <a href="/contact">联系</a>
    </div>

    <div class="header">
      <img
        src="https://raw.githubusercontent.com/liupuzhi/mysite/main/assets/01.png"
        alt="HJ"
        class="avatar"
      />
      <h1>H J</h1>
      <div class="subtitle">中山大学</div>

      <div class="bio">
        <p>大家好，我是HJ。</p>
        <p>欢迎和我交流～</p>
      </div>

      <div class="social-links">
        <a href="https://github.com/" target="_blank" title="GitHub"><i class="fab fa-github"></i></a>
        <a href="https://bilibili.com/" target="_blank" title="Bilibili"><i class="fab fa-bilibili"></i></a>
        <a href="https://www.youtube.com/" target="_blank" title="YouTube"><i class="fab fa-youtube"></i></a>
        <a href="mailto:xiaoranyu0807@gmail.com" title="邮箱"><i class="fas fa-envelope"></i></a>
      </div>
    </div>

    <audio id="bgMusic" loop>
      <source src="https://raw.githubusercontent.com/liupuzhi/mysite/main/assets/surprising_media-romantic-acoustic-guitar-1-433555.mp3" type="audio/mpeg">
    </audio>

    <button class="music-control" id="musicBtn" title="播放音乐">
      <i class="fas fa-volume-mute"></i>
    </button>
  </div>

  <script>
    const music = document.getElementById('bgMusic');
    const btn = document.getElementById('musicBtn');
    const icon = btn.querySelector('i');
    let isPlaying = false;

    btn.addEventListener('click', () => {
      if (isPlaying) {
        music.pause();
        icon.className = 'fas fa-volume-mute';
      } else {
        music.play().catch(e => {
          console.log('自动播放被阻止，需要用户交互');
        });
        icon.className = 'fas fa-volume-up';
      }
      isPlaying = !isPlaying;
    });
  </script>

  <style>
    @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      color: #333;
      background: #000;
      min-height: 100vh;
    }

    .bg {
      position: fixed;
      inset: 0;
      background: url('https://raw.githubusercontent.com/liupuzhi/mysite/main/assets/02.png') center/cover no-repeat;
      z-index: -2;
    }

    .bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255, 255, 255, 0.65);
      z-index: -1;
    }

    .nav {
      position: fixed;
      top: 2rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 2rem;
      background: rgba(255, 255, 255, 0.85);
      padding: 0.8rem 2rem;
      border-radius: 50px;
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      z-index: 200;
    }

    .container {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 6rem 2rem 2rem;
      position: relative;
    }

    .nav a {
      text-decoration: none;
      color: #555;
      font-weight: 600;
      font-size: 1.05rem;
      transition: all 0.3s;
      padding: 0.5rem 1rem;
      border-radius: 30px;
    }

    .nav a:hover,
    .nav a.active {
      color: #667eea;
      background: rgba(102, 126, 234, 0.1);
    }

    .header {
      background: rgba(255, 255, 255, 0.9);
      padding: 3rem;
      border-radius: 24px;
      box-shadow: 0 15px 50px rgba(0, 0, 0, 0.15);
      max-width: 800px;
      backdrop-filter: blur(20px);
    }

    .avatar {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid #fff;
      margin-bottom: 1.5rem;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    h1 {
      font-size: 3.5rem;
      font-weight: 800;
      color: #1a1a1a;
      margin-bottom: 0.5rem;
      letter-spacing: -0.5px;
    }

    .subtitle {
      font-size: 1.4rem;
      color: #555;
      margin-bottom: 2rem;
    }

    .bio {
      font-size: 1.1rem;
      line-height: 1.8;
      color: #444;
      margin-bottom: 2.5rem;
      max-width: 600px;
    }

    .social-links {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      margin-bottom: 2rem;
    }

    .social-links a {
      width: 55px;
      height: 55px;
      border-radius: 50%;
      background: white;
      color: #667eea;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      text-decoration: none;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .social-links a:hover {
      transform: translateY(-4px) scale(1.1);
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }

    .music-control {
      position: fixed;
      bottom: 20px;
      right: 20px;
      width: 60px;
      height: 60px;
      border-radius: 50%;
      border: none;
      background: rgba(255, 255, 255, 0.9);
      color: #667eea;
      font-size: 1.5rem;
      cursor: pointer;
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
      transition: all 0.3s;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .music-control:hover {
      transform: scale(1.1);
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }

    @media (max-width: 768px) {
      .nav {
        top: 1rem;
        flex-wrap: wrap;
        gap: 0.8rem;
        padding: 0.6rem;
      }

      .nav a {
        font-size: 0.95rem;
        padding: 0.4rem 0.8rem;
      }

      .header {
        padding: 2rem;
        max-width: 100%;
      }

      .avatar {
        width: 140px;
        height: 140px;
      }

      h1 {
        font-size: 2.5rem;
      }

      .subtitle {
        font-size: 1.1rem;
      }

      .bio {
        font-size: 1rem;
      }

      .social-links {
        gap: 1rem;
      }

      .social-links a {
        width: 45px;
        height: 45px;
        font-size: 1.2rem;
      }

      .music-control {
        width: 50px;
        height: 50px;
        font-size: 1.3rem;
      }
    }
  </style>
</Layout>
