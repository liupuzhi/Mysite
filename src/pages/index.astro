---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HJ - 首页">
  <div class="bg"></div>

  <div class="container">
    <div class="nav">
      <a href="/" class="active">首页</a>
      <a href="/projects">作品集</a>
      <a href="/about">关于</a>
      <a href="/contact">联系</a>
    </div>

    <div class="header">
      <img
        src="https://raw.githubusercontent.com/liupuzhi/mysite/main/assets/01.png"
        alt="HJ"
        class="avatar"
      />
      <h1>H J</h1>
      <div class="subtitle">中山大学</div>

      <div class="bio">
        <p>大家好，我是HJ。</p>
        <p>欢迎和我交流～</p>
      </div>

      <div class="social-links">
        <a href="https://github.com/" target="_blank" title="GitHub">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-2.461 0-.543.197-1.001.529-1.357-1.332-.152-2.728-.664-2.728-3.067 0-.673.238-1.258.627-1.726-.501-1.411-1.104-2.616-1.104-2.616s-.595-.302-.595-1.26c0-1.181.626-1.752.626-1.752 1.165-.039 2.393 1.195 2.393 1.195.684-.391 1.43-.591 2.232-.591.797 0 1.543.2 2.227.591 0 0 1.23-1.234 2.393-1.195 0 0 .625.571.625 1.752 0 .958-.594 1.26-.594 1.26-.302.88-.42 1.729.625 2.616.411.343.628.952.628 1.726 0 1.735-2.801 2.762-5.469 3.067.441.379.839 1.126.839 2.27v3.371c0 .319.193.695.797.578C20.563 21.793 24 17.295 24 12c0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="https://bilibili.com/" target="_blank" title="Bilibili">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor"><path d="M19.113 18.886c-.18.182-.452.353-.686.411-.355.089-5.52.082-6.055.003-.325-.048-.76-.297-.957-.578-.318-.454-.238-1.277.17-1.707.323-.341.887-.61 1.283-.61.355 0 .412.007 1.447.017.402.004.986.008 1.45.017.722.014 1.087.029 1.481.119.664.151 1.378.562 1.773 1.023.417.488.581 1.104.432 1.687-.07.275-.174.454-.338.618zM7.55 18.88c-.182.181-.453.352-.687.41-.355.089-5.52.083-6.055.004-.325-.048-.76-.297-.957-.579-.318-.454-.237-1.276.17-1.707.324-.34.888-.61 1.284-.61.356 0 .412.008 1.447.018.402.004.986.007 1.45.016.722.015 1.087.03 1.481.12.663.15 1.377.562 1.773 1.022.417.488.581 1.104.432 1.687-.07.276-.175.455-.338.619zm14.72-5.37c-.24.149-2.336 1.516-3.043 1.98-.776.51-1.395.497-1.823.06-.428-.438-.367-1.134.17-1.565.41-.329 4.212-2.758 4.398-2.87.187-.112.45-.158.64-.145.485.033.862.46.862.97 0 .428-.253.97-1.204 1.57zm-14.665.004c-.24.148-2.335 1.515-3.042 1.98-.777.51-1.395.496-1.823.058-.429-.438-.368-1.134.169-1.565.41-.329 4.213-2.758 4.398-2.87.187-.111.45-.157.64-.144.486.033.863.46.863.97 0 .428-.254.97-1.205 1.571z"/></svg>
        </a>
        <a href="https://www.youtube.com/" target="_blank" title="YouTube">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="mailto:xiaoranyu0807@gmail.com" title="邮箱"><i class="fas fa-envelope"></i></a>
      </div>
    </div>

    <audio id="bgMusic" loop>
      <source src="https://raw.githubusercontent.com/liupuzhi/mysite/main/assets/surprising_media-romantic-acoustic-guitar-1-433555.mp3" type="audio/mpeg">
    </audio>

    <button class="music-control" id="musicBtn" title="播放音乐">
      <i class="fas fa-volume-mute"></i>
    </button>
  </div>

  <script>
    const music = document.getElementById('bgMusic');
    const btn = document.getElementById('musicBtn');
    const icon = btn.querySelector('i');
    let isPlaying = false;

    btn.addEventListener('click', () => {
      if (isPlaying) {
        music.pause();
        icon.className = 'fas fa-volume-mute';
      } else {
        music.play().catch(e => {
          console.log('自动播放被阻止，需要用户交互');
        });
        icon.className = 'fas fa-volume-up';
      }
      isPlaying = !isPlaying;
    });
  </script>

  <style>
    @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css');
    @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/solid.min.css');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      color: #333;
      background: #000;
      min-height: 100vh;
    }

    .bg {
      position: fixed;
      inset: 0;
      background: url('https://raw.githubusercontent.com/liupuzhi/mysite/main/assets/02.png') center/cover no-repeat;
      z-index: -2;
    }

    .bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255, 255, 255, 0.65);
      z-index: -1;
    }

    .nav {
      position: fixed;
      top: 2rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 2rem;
      background: rgba(255, 255, 255, 0.85);
      padding: 0.8rem 2rem;
      border-radius: 50px;
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      z-index: 200;
    }

    .container {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 6rem 2rem 2rem;
      position: relative;
    }

    .nav a {
      text-decoration: none;
      color: #555;
      font-weight: 600;
      font-size: 1.05rem;
      transition: all 0.3s;
      padding: 0.5rem 1rem;
      border-radius: 30px;
    }

    .nav a:hover,
    .nav a.active {
      color: #667eea;
      background: rgba(102, 126, 234, 0.1);
    }

    .header {
      background: rgba(255, 255, 255, 0.9);
      padding: 3rem;
      border-radius: 24px;
      box-shadow: 0 15px 50px rgba(0, 0, 0, 0.15);
      max-width: 800px;
      backdrop-filter: blur(20px);
    }

    .avatar {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid #fff;
      margin-bottom: 1.5rem;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    h1 {
      font-size: 3.5rem;
      font-weight: 800;
      color: #1a1a1a;
      margin-bottom: 0.5rem;
      letter-spacing: -0.5px;
    }

    .subtitle {
      font-size: 1.4rem;
      color: #555;
      margin-bottom: 2rem;
    }

    .bio {
      font-size: 1.1rem;
      line-height: 1.8;
      color: #444;
      margin-bottom: 2.5rem;
      max-width: 600px;
    }

    .social-links {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      margin-bottom: 2rem;
    }

    .social-links a {
      width: 55px;
      height: 55px;
      border-radius: 50%;
      background: white;
      color: #667eea;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      text-decoration: none;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .social-links a .icon {
      width: 28px;
      height: 28px;
      fill: currentColor;
    }

    .social-links a:hover {
      transform: translateY(-4px) scale(1.1);
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }

    .music-control {
      position: fixed;
      bottom: 20px;
      right: 20px;
      width: 60px;
      height: 60px;
      border-radius: 50%;
      border: none;
      background: rgba(255, 255, 255, 0.9);
      color: #667eea;
      font-size: 1.5rem;
      cursor: pointer;
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
      transition: all 0.3s;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .music-control:hover {
      transform: scale(1.1);
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }

    @media (max-width: 768px) {
      .nav {
        top: 1rem;
        flex-wrap: wrap;
        gap: 0.8rem;
        padding: 0.6rem;
      }

      .nav a {
        font-size: 0.95rem;
        padding: 0.4rem 0.8rem;
      }

      .header {
        padding: 2rem;
        max-width: 100%;
      }

      .avatar {
        width: 140px;
        height: 140px;
      }

      h1 {
        font-size: 2.5rem;
      }

      .subtitle {
        font-size: 1.1rem;
      }

      .bio {
        font-size: 1rem;
      }

      .social-links {
        gap: 1rem;
      }

      .social-links a {
        width: 45px;
        height: 45px;
        font-size: 1.2rem;
      }

      .music-control {
        width: 50px;
        height: 50px;
        font-size: 1.3rem;
      }
    }
  </style>
</Layout>
