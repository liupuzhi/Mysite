---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HJ - 首页">
  <div class="bg"></div>

  <div class="container">
    <div class="nav">
      <a href="/" class="active">首页</a>
      <a href="/projects">作品集</a>
      <a href="/about">关于</a>
      <a href="/contact">联系</a>
    </div>

    <div class="header">
      <img
        src="https://raw.githubusercontent.com/liupuzhi/mysite/main/assets/01.png"
        alt="HJ"
        class="avatar"
      />
      <h1>H J</h1>
      <div class="subtitle">中山大学</div>

      <div class="bio">
        <p>大家好，我是HJ。</p>
        <p>欢迎和我交流～</p>
      </div>

      <div class="social-links">
        <a href="https://github.com/" target="_blank" title="GitHub">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
            <!-- GitHub 图标 - 蓝色 -->
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" fill="#00AEEC"/>
          </svg>
        </a>
        <a href="https://space.bilibili.com/" target="_blank" title="Bilibili">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
            <path fill="#00AEEC" d="M17.523 2.999a1.535 1.535 0 0 0-1.462 1.078 2.53 2.53 0 0 1-2.343 1.683h-.036a2.53 2.53 0 0 1-2.343-1.683 1.535 1.535 0 0 0-1.462-1.078C8.367 2.999 7 4.544 7 7.587v1.055c0 1.997-.373 3.86-2.066 4.714a.526.526 0 0 0-.228.674c.647 1.698 1.712 2.89 2.89 3.412v1.985a.586.586 0 0 0 .586.586h1.173a.586.586 0 0 0 .586-.586V18.22c.693.09 1.404.137 2.116.137s1.423-.047 2.116-.137v1.208a.586.586 0 0 0 .586.586h1.173a.586.586 0 0 0 .586-.586v-1.985c1.178-.522 2.243-1.714 2.89-3.412a.526.526 0 0 0-.228-.674c-1.693-.854-2.066-2.717-2.066-4.714V7.587c0-3.043-1.367-4.588-2.89-4.588zM9.943 13.74a1.53 1.53 0 1 1 0-3.06 1.53 1.53 0 0 1 0 3.06zm5.123-1.53a1.53 1.53 0 1 1-3.06 0 1.53 1.53 0 0 1 3.06 0z"/>
          </svg>
        </a>
        <a href="https://www.youtube.com/" target="_blank" title="YouTube">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
            <!-- YouTube 图标 - 蓝色 -->
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" fill="#00AEEC"/>
          </svg>
        </a>
        <a href="mailto:xiaoranyu0807@gmail.com" title="邮箱">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
            <!-- 邮箱图标 - 蓝色 -->
            <path d="M12 12.713l-11.985-9.713h23.97L12 12.713zM0 20.287V4.969l11.26 9.128c.41.332.94.332 1.35 0L24 4.969v15.318H0z" fill="#00AEEC"/>
          </svg>
        </a>
      </div>
    </div>

    <audio id="bgMusic" loop>
      <source src="https://raw.githubusercontent.com/liupuzhi/mysite/main/assets/surprising_media-romantic-acoustic-guitar-1-433555.mp3" type="audio/mpeg">
    </audio>

    <button class="music-control" id="musicBtn" title="播放音乐">
      <i class="fas fa-volume-mute"></i>
    </button>
  </div>

  <script>
    const music = document.getElementById('bgMusic');
    const btn = document.getElementById('musicBtn');
    const icon = btn.querySelector('i');
    let isPlaying = false;

    btn.addEventListener('click', () => {
      if (isPlaying) {
        music.pause();
        icon.className = 'fas fa-volume-mute';
      } else {
        music.play().catch(e => {
          console.log('自动播放被阻止，需要用户交互');
        });
        icon.className = 'fas fa-volume-up';
      }
      isPlaying = !isPlaying;
    });
  </script>

  <style>
    @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css');
    @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/solid.min.css');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      color: #333;
      background: #000;
      min-height: 100vh;
    }

    .bg {
      position: fixed;
      inset: 0;
      background: url('https://raw.githubusercontent.com/liupuzhi/mysite/main/assets/02.png') center/cover no-repeat;
      z-index: -2;
    }

    .bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255, 255, 255, 0.65);
      z-index: -1;
    }

    .nav {
      position: fixed;
      top: 2rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 2rem;
      background: rgba(255, 255, 255, 0.85);
      padding: 0.8rem 2rem;
      border-radius: 50px;
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      z-index: 200;
    }

    .container {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 6rem 2rem 2rem;
      position: relative;
    }

    .nav a {
      text-decoration: none;
      color: #555;
      font-weight: 600;
      font-size: 1.05rem;
      transition: all 0.3s;
      padding: 0.5rem 1rem;
      border-radius: 30px;
    }

    .nav a:hover,
    .nav a.active {
      color: #667eea;
      background: rgba(102, 126, 234, 0.1);
    }

    .header {
      background: rgba(255, 255, 255, 0.9);
      padding: 3rem;
      border-radius: 24px;
      box-shadow: 0 15px 50px rgba(0, 0, 0, 0.15);
      max-width: 800px;
      backdrop-filter: blur(20px);
    }

    .avatar {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid #fff;
      margin-bottom: 1.5rem;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    h1 {
      font-size: 3.5rem;
      font-weight: 800;
      color: #1a1a1a;
      margin-bottom: 0.5rem;
      letter-spacing: -0.5px;
    }

    .subtitle {
      font-size: 1.4rem;
      color: #555;
      margin-bottom: 2rem;
    }

    .bio {
      font-size: 1.1rem;
      line-height: 1.8;
      color: #444;
      margin-bottom: 2.5rem;
      max-width: 600px;
    }

    .social-links {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      margin-bottom: 2rem;
    }

    .social-links a {
      width: 55px;
      height: 55px;
      border-radius: 50%;
      background: white;
      color: #667eea;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      text-decoration: none;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .social-links a .icon {
      width: 28px;
      height: 28px;
      fill: currentColor;
    }

    .social-links a:hover {
      transform: translateY(-4px) scale(1.1);
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }

    .music-control {
      position: fixed;
      bottom: 20px;
      right: 20px;
      width: 60px;
      height: 60px;
      border-radius: 50%;
      border: none;
      background: rgba(255, 255, 255, 0.9);
      color: #667eea;
      font-size: 1.5rem;
      cursor: pointer;
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
      transition: all 0.3s;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .music-control:hover {
      transform: scale(1.1);
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }

    @media (max-width: 768px) {
      .nav {
        top: 1rem;
        flex-wrap: wrap;
        gap: 0.8rem;
        padding: 0.6rem;
      }

      .nav a {
        font-size: 0.95rem;
        padding: 0.4rem 0.8rem;
      }

      .header {
        padding: 2rem;
        max-width: 100%;
      }

      .avatar {
        width: 140px;
        height: 140px;
      }

      h1 {
        font-size: 2.5rem;
      }

      .subtitle {
        font-size: 1.1rem;
      }

      .bio {
        font-size: 1rem;
      }

      .social-links {
        gap: 1rem;
      }

      .social-links a {
        width: 45px;
        height: 45px;
        font-size: 1.2rem;
      }

      .music-control {
        width: 50px;
        height: 50px;
        font-size: 1.3rem;
      }
    }
  </style>
</Layout>
